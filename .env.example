# APP SETTINGS
APP_NAME="SEO Studio"
SECRET_KEY="your-super-secret-key-change-it"
PORT=8090

# AUTH (single admin)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD_HASH="$2b$12$replace_with_bcrypt_hash"
SESSION_COOKIE_NAME="seo_session"
SESSION_MAX_AGE_SECONDS=604800

# DATABASE
DATABASE_URL="sqlite+aiosqlite:///./seo_studio.db"

# SEO SETTINGS
CHECK_INTERVAL_HOURS=2
USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/122.0.0.0 Safari/537.36"

# AI (Ollama)
AI_PROVIDER="auto"
AI_MODEL=""
OLLAMA_BASE_URL="http://127.0.0.1:11434"
AI_TIMEOUT_SECONDS=8.0

# SMTP (email alerts)
SMTP_HOST=""
SMTP_PORT=587
SMTP_USERNAME=""
SMTP_PASSWORD=""
SMTP_FROM_EMAIL=""
SMTP_USE_TLS=true
